# ============================================================
# AIS Middleware Platform — Environment Variable Reference
# Copy to .env and override values as needed for local dev.
# ============================================================

# ── Grafana ──────────────────────────────────────────────────
# Admin password for Grafana UI (http://localhost:3001)
GF_SECURITY_ADMIN_PASSWORD=admin

# ── Particular ServiceControl (NServiceBus SQL Server Transport) ─────────────
# Connection string for ServiceControl, ServiceControl-Audit, and Monitoring.
# Must point to the same SQL Server instance used by the dotnet services.
MESSAGING_CONNECTION_STRING=Server=sqlserver;Database=middleware_nsb;User Id=sa;Password=AIS_Middleware_2024!;TrustServerCertificate=True

# ── Backend Stack Toggle ──────────────────────────────────────
# Controls which backend stack the Platform UI routes requests to.
# java   (default) → Java/Apache Camel stack (port 8081)
# dotnet           → .NET/NServiceBus stack (port 8181)
# Set to 'dotnet' to switch the UI to the .NET implementation.
ACTIVE_BACKEND=java
